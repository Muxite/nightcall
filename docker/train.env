# Nightcall training — single source of defaults for Docker Compose.
# Compose loads this file into the container; override per machine via a root `.env`
# or `VAR=value docker compose run ...` (host env wins over this file when passed through).
# python/training/train.py reads the same variable names (see _cli_defaults).

TOTAL_STEPS=1000000
NUM_ENVS=8
P2_POLICY=scripted
CHECKPOINT_DIR=/workspace/checkpoints
LOAD_CHECKPOINT=
RESUME=0

# Weights + optional TensorBoard-style artifacts (same layout as local sweep: MP4 + JSONL + metrics)
RESULTS_DIR=/workspace/results
# Set to 1 to run render_run after training (baseline.mp4, trained.mp4, replays, metrics.txt)
RENDER_AFTER_TRAIN=1
# Replay scenario (defaults match NightcallEnv: 30×30, 4v4)
RENDER_MAP_SIZE=30
RENDER_P1_UNITS=4
RENDER_P2_UNITS=4
RENDER_FPS=15
RENDER_RUN_NAME=docker_run
